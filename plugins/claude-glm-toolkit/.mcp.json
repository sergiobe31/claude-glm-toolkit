{
  "mcpServers": {
    "pal": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/BeehiveInnovations/pal-mcp-server.git",
        "pal-mcp-server"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${user_config.openrouter_api_key}",
        "DEFAULT_MODEL": "auto",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
